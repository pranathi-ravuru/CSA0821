numbers = list(map(int, input("Enter numbers separated by space: ").split()))
numbers.sort()

# Find Mean
mean = sum(numbers) / len(numbers)

# Find Median
n = len(numbers)
if n % 2 == 0:
    median = (numbers[n//2 - 1] + numbers[n//2]) / 2
else:
    median = numbers[n//2]

# Find Mode
mode = max(numbers, key = numbers.count)

# Display results
print("Mean =", mean)
print("Median =", median)
print("Mode =", mode)
